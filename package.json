{
  "name": "voiceos-malayalam-backend",
  "version": "1.0.0",
  "description": "Malayalam IVR Voice Agent Platform — Kerala Paints",
  "main": "server.js",
  "scripts": {
    "start":       "node server.js",
    "dev":         "nodemon server.js",
    "dev:ui":      "cd client && npm run dev",
    "build:ui":    "cd client && npm install && npm run build",
    "db:migrate":  "node db/index.js migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk":            "^0.39.0",
    "@google-cloud/speech":         "^6.7.0",
    "@google-cloud/text-to-speech": "^5.3.0",
    "cors":                         "^2.8.5",
    "dotenv":                       "^16.4.5",
    "express":                      "^4.19.2",
    "express-rate-limit":           "^7.3.1",
    "helmet":                       "^7.1.0",
    "multer":                       "^1.4.5-lts.1",
    "pg":                           "^8.12.0",
    "twilio":                       "^5.2.0",
    "uuid":                         "^10.0.0",
    "winston":                      "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
